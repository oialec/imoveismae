# Supabase - encontre em: https://app.supabase.com -> seu projeto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Número de WhatsApp da corretora (apenas números, com DDI)
# Exemplo: 5513999999999 (55 = Brasil, 13 = litoral SP, 999999999 = número)
NEXT_PUBLIC_WHATSAPP_NUMBER=5513999999999

# Nome da corretora (aparece no header, footer e cards)
NEXT_PUBLIC_NOME_CORRETORA=Selma Villar

# Número do CRECI
NEXT_PUBLIC_CRECI=167207-F

# Ano de início da corretora (para o footer)
NEXT_PUBLIC_ANO_INICIO=2012
